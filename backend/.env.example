# ══════════════════════════════════════════════════════════════════════════════
#  HealthAI — Environment Configuration Template
#  Copy to .env and fill in your values:
#    Windows:  copy .env.example .env
#    Linux:    cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════


# ── Django Core ────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-use-50-plus-random-chars-in-production

# true for local development, false for production
DJANGO_DEBUG=true

# Comma-separated. Add your domain in production.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500


# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# REQUIRED. Create the database first: CREATE DATABASE "chat-bot";
DB_ENGINE=django.db.backends.postgresql
DB_NAME=chat-bot
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password-here
DB_HOST=localhost
DB_PORT=5432


# ── Redis ──────────────────────────────────────────────────────────────────────
# Optional in dev — app falls back to in-memory cache without it.
# Required for async jobs, caching, and rate limiting.
REDIS_URL=redis://127.0.0.1:6379/1
RQ_ANALYSIS_QUEUE=analysis
RQ_JOB_TIMEOUT=600


# ── JWT / Cookie Auth ──────────────────────────────────────────────────────────
# Set JWT_COOKIE_SECURE=true in production (requires HTTPS)
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_ACCESS_COOKIE_NAME=healthcare_access
JWT_REFRESH_COOKIE_NAME=healthcare_refresh
# JWT_COOKIE_DOMAIN=yourdomain.com


# ── Security ───────────────────────────────────────────────────────────────────
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_SUBDOMAINS=false
DJANGO_HSTS_PRELOAD=false


# ── Rate Limiting ──────────────────────────────────────────────────────────────
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=120/minute
THROTTLE_AUTH_RATE=10/minute
THROTTLE_ANALYZE_RATE=20/minute


# ── Brute-Force Login Protection ──────────────────────────────────────────────
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15


# ── Maps & Location ────────────────────────────────────────────────────────────
# Geoapify — PRIMARY (free, no billing). Get key: https://www.geoapify.com/
GEOAPIFY_API_KEY=your-geoapify-api-key-here

# Google Maps — SECONDARY fallback (requires billing enabled in Google Cloud)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_PLACES_RADIUS_METERS=5000

# Google Custom Search — for web search in RAG pipeline (optional)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CSE_ID=

# Redis cache TTL for Places API results (seconds)
PLACES_CACHE_TTL_SECONDS=3600


# ── Social Login (OAuth) ───────────────────────────────────────────────────────
# Leave blank to disable. After setting, run: python manage.py seed_social_apps

# Google — https://console.cloud.google.com/
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_SECRET=

# GitHub — https://github.com/settings/developers
SOCIAL_GITHUB_CLIENT_ID=
SOCIAL_GITHUB_SECRET=

# Microsoft — https://portal.azure.com/
SOCIAL_MICROSOFT_CLIENT_ID=
SOCIAL_MICROSOFT_SECRET=

# Facebook — https://developers.facebook.com/
SOCIAL_FACEBOOK_CLIENT_ID=
SOCIAL_FACEBOOK_SECRET=

# Apple — https://developer.apple.com/
SOCIAL_APPLE_CLIENT_ID=
SOCIAL_APPLE_SECRET=

ALLAUTH_SITE_ID=1
ALLAUTH_EMAIL_VERIFICATION=none
SITE_DOMAIN=localhost


# ── Email ──────────────────────────────────────────────────────────────────────
# Dev: console backend prints to terminal (no SMTP needed)
# Prod: use smtp and fill in credentials below
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@healthcare-ai.local
FRONTEND_BASE_URL=http://127.0.0.1:8000


# ── ML Models ──────────────────────────────────────────────────────────────────
# All paths default to backend/models/ — only set these if you move the files.
# TEXT_MODEL_PATH=
# TFIDF_VECTORIZER_PATH=
# TEXT_LABELS_PATH=
# TRIAGE_LABEL_CONSOLIDATION_PATH=
# IMAGE_TORCH_MODEL_PATH=
# IMAGE_LABELS_PATH=
# IMAGE_MODEL_METADATA_PATH=
# CONDITION_NAME_MAP_PATH=
# DIALOGUE_INTENT_MODEL_PATH=
# DIALOGUE_INTENT_VECTORIZER_PATH=
# DIALOGUE_INTENT_CONSOLIDATION_PATH=
# DIALOGUE_RESPONSE_TEMPLATES_PATH=

IMAGE_INPUT_SIZE=64
TEXT_SVD_PATH=


# ── LLM Triage (GitHub Models — cloud, no GPU needed) ───────────────────────
# Get your token at: https://github.com/settings/tokens (needs "models" scope)
GITHUB_TOKEN=your-github-token-here
USE_LLM_TRIAGE=true
LLM_FALLBACK_TO_CLASSICAL=true
TRIAGE_LLM_BASE_MODEL=meta/Llama-4-Maverick-17B-128E-Instruct-FP8
LLM_RAG_RESPONSE=true


# ── Data Retention ─────────────────────────────────────────────────────────────
CASE_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365


# ── SSE Streaming ──────────────────────────────────────────────────────────────
SSE_POLL_INTERVAL_SECONDS=1.5
SSE_MAX_WAIT_SECONDS=620
